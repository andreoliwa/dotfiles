#!/usr/bin/env bash
# ~/.bashrc — Interactive non-login shell init.
# All configuration lives in ~/.config/shell.d/ fragments.
# This file should rarely need editing.

# Guard: only run for interactive shells
[[ $- != *i* ]] && return

# Both .bash_profile and .bashrc source shell.d because bash only reads one per session type:
# login shells read .bash_profile (SSH, terminal apps on macOS), interactive non-login shells
# read .bashrc (tmux panes, nested bash, `bash -i`). The SHELL_D_LOADED guard prevents double-loading.

# If shell.d fragments weren't already loaded by .bash_profile (login shell),
# source them now. This handles: ssh remote-host, tmux new panes, etc.
if [[ -z "$SHELL_D_LOADED" ]]; then
    for f in ~/.config/shell.d/*.sh; do
        # shellcheck source=/dev/null
        [[ -r "$f" ]] || continue

        # Set DOTF_BENCHMARK=1 to print each fragment's load time (requires gdate: brew install coreutils).
        if [[ -n "$DOTF_BENCHMARK" ]]; then
            _t0=$(gdate +%s.%6N)
            source "$f"
            _t1=$(gdate +%s.%6N)
            printf "%.3f s  %s\n" "$(echo "$_t1 - $_t0" | bc)" "$f"
        else
            source "$f"
        fi
    done
    export SHELL_D_LOADED=1
fi
