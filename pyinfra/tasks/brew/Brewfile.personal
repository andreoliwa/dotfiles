# Brewfile.personal - personal_laptop-only entries from group_vars/all.yml.
# Common entries live in Brewfile.common; brew.py loads both.

# Taps

# Brews
brew "gromgit/fuse/ntfs-3g-mac"  # Read-write NTFS driver for FUSE https://www.tuxera.com/community/open-source-ntfs-3g/

# Casks
cask "brave-browser"  # https://brave.com/
cask "brave-browser@beta"  # https://brave.com/download-beta/
cask "transmission-remote-gui"  # https://github.com/transmission-remote-gui/transgui
