# Brewfile.company - company_laptop-only entries from group_vars/all.yml.
# Common entries live in Brewfile.common; brew.py loads both.

# Taps

# Brews
brew "actionlint"  # https://github.com/rhysd/actionlint
brew "aviator-co/tap/av"  # https://github.com/aviator-co/av
brew "aws-iam-authenticator"  # https://docs.aws.amazon.com/eks/latest/userguide/install-aws-iam-authenticator.html
brew "awscli"  # https://aws.amazon.com/cli/ Newer versions 2.*
brew "gradle-completion"  # https://github.com/gradle/gradle-completion
brew "mike-engel/jwt-cli/jwt-cli"  # https://github.com/mike-engel/jwt-cli
brew "protobuf"  # https://github.com/protocolbuffers/protobuf
tap "hashicorp/tap"  # https://github.com/hashicorp/homebrew-tap (vault left homebrew-core after BSL license change)
brew "hashicorp/tap/vault"  # Hashicorp https://www.vaultproject.io/

# Casks
cask "aws-vault"  # https://github.com/99designs/aws-vault#installing
cask "granola"  # https://www.granola.ai/
cask "postman"  # https://www.postman.com/
cask "slack"  # https://slack.com/
